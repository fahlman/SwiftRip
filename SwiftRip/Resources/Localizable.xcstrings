    "Stopping now will terminate HandBrakeCLI and delete the incomplete output file.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stopping now will terminate HandBrakeCLI and delete the incomplete output file."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si detienes ahora, se terminará HandBrakeCLI y se eliminará el archivo de salida incompleto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrêter maintenant mettra fin à HandBrakeCLI et supprimera le fichier de sortie incomplet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn du jetzt stoppst, wird HandBrakeCLI beendet und die unvollständige Ausgabedatei gelöscht."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今停止するとHandBrakeCLIを終了し、未完了の出力ファイルを削除します。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Interrompendo ora, HandBrakeCLI verrà terminato e il file di output incompleto verrà eliminato."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Parar agora encerrará o HandBrakeCLI e apagará o arquivo de saída incompleto."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als je nu stopt, wordt HandBrakeCLI beëindigd en wordt het onvolledige uitvoerbestand verwijderd."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "现在停止将终止 HandBrakeCLI 并删除不完整的输出文件。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지금 중지하면 HandBrakeCLI가 종료되고 불완전한 출력 파일이 삭제됩니다."
          }
        }
      }
    },

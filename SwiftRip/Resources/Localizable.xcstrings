    "%@ failed with exit code %d.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ failed with exit code %d."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ falló con el código de salida %d."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ a échoué avec le code de sortie %d."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ist mit Exit-Code %d fehlgeschlagen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@は終了コード%dで失敗しました。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ non riuscito con codice di uscita %d."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ falhou com o código de saída %d."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ is mislukt met afsluitcode %d."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 失败，退出代码为 %d。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@이(가) 종료 코드 %d로 실패했습니다."
          }
        }
      }
    },
    "%@ includes bundled third-party tools. Their license files are included in the app bundle resources.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ includes bundled third-party tools. Their license files are included in the app bundle resources."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ incluye herramientas de terceros integradas. Sus archivos de licencia se incluyen en los recursos del paquete de la app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ inclut des outils tiers intégrés. Leurs fichiers de licence sont inclus dans les ressources du bundle de l’app."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ enthält gebündelte Drittanbieterwerkzeuge. Deren Lizenzdateien sind in den Ressourcen des App-Bundles enthalten."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@には同梱されたサードパーティ製ツールが含まれています。それらのライセンスファイルはアプリバンドルのリソースに含まれています。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ include strumenti di terze parti incorporati. I relativi file di licenza sono inclusi nelle risorse del bundle dell’app."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ inclui ferramentas de terceiros integradas. Os arquivos de licença delas estão incluídos nos recursos do pacote do app."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ bevat meegeleverde hulpprogramma’s van derden. Hun licentiebestanden zijn opgenomen in de appbundelresources."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 包含捆绑的第三方工具。其许可证文件包含在应用包资源中。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@에는 번들로 포함된 타사 도구가 포함되어 있습니다. 해당 라이선스 파일은 앱 번들 리소스에 포함되어 있습니다."
          }
        }
      }
    },

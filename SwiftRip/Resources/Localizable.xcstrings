    "SwiftRip needs permission to save ripped movies outside its app container. Choose Movies or another output folder.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "SwiftRip needs permission to save ripped movies outside its app container. Choose Movies or another output folder."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "SwiftRip necesita permiso para guardar películas extraídas fuera de su contenedor de app. Elige Películas u otra carpeta de salida."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "SwiftRip a besoin d’une autorisation pour enregistrer les films extraits hors de son conteneur d’app. Choisissez Films ou un autre dossier de sortie."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "SwiftRip benötigt die Erlaubnis, gerippte Filme außerhalb seines App-Containers zu speichern. Wähle „Filme“ oder einen anderen Ausgabeordner."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "SwiftRipがアプリコンテナの外にリッピングしたムービーを保存するには許可が必要です。「ムービー」または別の出力フォルダを選択してください。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "SwiftRip richiede il permesso per salvare i film estratti fuori dal contenitore dell’app. Scegli Film o un’altra cartella di output."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O SwiftRip precisa de permissão para salvar filmes extraídos fora do contêiner do app. Escolha Filmes ou outra pasta de saída."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "SwiftRip heeft toestemming nodig om geripte films buiten de appcontainer te bewaren. Kies Films of een andere uitvoermap."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "SwiftRip 需要权限才能将翻录影片保存到应用容器之外。请选择“影片”或其他输出文件夹。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "SwiftRip이 앱 컨테이너 밖에 리핑한 동영상을 저장하려면 권한이 필요합니다. 동영상 또는 다른 출력 폴더를 선택하세요."
          }
        }
      }
    },
